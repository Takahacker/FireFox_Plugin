{
  "manifest_version": 2,
  "name": "Privacy Guard",
  "version": "1.0.0",
  "description": "Detects and reports privacy threats, tracking, and browser fingerprinting on web pages.",

  "permissions": [
    "webRequest",
    "cookies",
    "storage",
    "tabs",
    "activeTab",
    "<all_urls>"
  ],

  "background": {
    "scripts": ["background.js"],
    "persistent": true
  },

  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["content.js"],
      "run_at": "document_start",
      "all_frames": false
    }
  ],

  "browser_action": {
    "default_popup": "popup.html",
    "default_title": "Privacy Guard"
  },

  "web_accessible_resources": ["inject.js"],

  "data_collection_permissions": {
    "useTechnicalAndInteractionData": false,
    "usePersonallyIdentifyingInfo": false
  }
}
